# Local env file for deploy script
deploy/.env.local
# Deploy logs / snapshots that may contain secrets (allow the example)
deploy/*.json
!deploy/.env.local.example
# Auto-generated deploy scripts with hardcoded DB values
deploy/apply_translations_prod.py
deploy/translation_sync.sql
# Django dumpdata / DB dumps -- contain user records & password hashes
prod_data.json
*.sql
duno360_backup.sql

# Documentation (allow deployment files)
*.md
*.txt
!README.md
!README.txt
!requirements.txt
