# deploy/.env.local.example
# Copy this to  deploy/.env.local  and fill in real values.
# The .env.local file is gitignored -- NEVER commit it.
#
# Usage (Windows CMD):
#   for /f "tokens=*" %i in (deploy\.env.local) do set %i
#   python deploy/deploy_new_vps.py
#
# Usage (PowerShell):
#   Get-Content deploy\.env.local | ForEach-Object { if ($_ -match '^([^#=]+)=(.*)$') { [System.Environment]::SetEnvironmentVariable($matches[1], $matches[2]) } }
#   python deploy/deploy_new_vps.py

DJANGO_SECRET_KEY=CHANGE_ME_generate_a_50char_random_string
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
SUPABASE_PROJECT_URL=https://<project-ref>.supabase.co
KKIAPAY_PUBLIC_KEY=YOUR_KKIAPAY_PUBLIC_KEY
KKIAPAY_PRIVATE_KEY=YOUR_KKIAPAY_PRIVATE_KEY
KKIAPAY_SECRET=YOUR_KKIAPAY_SECRET
KKIAPAY_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET
SUPABASE_S3_ACCESS_KEY_ID=YOUR_S3_ACCESS_KEY_ID
SUPABASE_S3_SECRET_ACCESS_KEY=YOUR_S3_SECRET_ACCESS_KEY
