# DUNO 360 production environment template
# Copy to server as /opt/duno360/.env and fill with real values.
# Do NOT commit real secrets.

# Django
DEBUG=False
SECRET_KEY=replace-with-a-long-random-secret
ALLOWED_HOSTS=159.203.186.103,your-domain.com,www.your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Database (Supabase Postgres)
# Keep password URL-encoded if it contains special characters.
DATABASE_URL=postgresql://postgres:<url-encoded-db-password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
DB_CONN_MAX_AGE=120
DATABASE_SSLMODE=require

# Optional Supabase client values (non-secret by design)
SUPABASE_PROJECT_URL=https://<project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=<your-supabase-publishable-key>

# Supabase Storage (S3 compatible) for static/media
SUPABASE_STORAGE_ENABLED=False
SUPABASE_STORAGE_BUCKET=duno360_bucket
SUPABASE_S3_REGION=us-east-1
SUPABASE_S3_ENDPOINT=https://<project-ref>.storage.supabase.co/storage/v1/s3
SUPABASE_S3_ACCESS_KEY_ID=<supabase-s3-access-key-id>
SUPABASE_S3_SECRET_ACCESS_KEY=<supabase-s3-secret-access-key>
# Optional override:
# SUPABASE_STORAGE_PUBLIC_BASE_URL=https://<project-ref>.supabase.co/storage/v1/object/public/duno360_bucket

# Email
EMAIL_HOST_USER=you@example.com
EMAIL_HOST_PASSWORD=replace-with-email-password

# Security defaults
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax

# App bootstrap
DJANGO_ADMIN_PASSWORD=replace-with-strong-admin-password
