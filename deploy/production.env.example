# DUNO 360 — Production .env (IONOS VPS)
# Copy to server:  cp deploy/production.env.example /opt/duno360/.env
# Edit secrets, then:  bash /opt/duno360/app/deploy/setup_ionos.sh
# Do NOT commit real secrets.
#
# Server: IONOS · Ubuntu 24.04 · 217.160.36.235

# ========== REQUIRED (site will not start without these) ==========
DEBUG=False
SECRET_KEY=replace-with-a-long-random-secret-min-50-chars
ALLOWED_HOSTS=217.160.36.235,duno360.com,www.duno360.com
CSRF_TRUSTED_ORIGINS=https://duno360.com,https://www.duno360.com
FORCE_HTTPS=True

# Supabase Postgres (URL-encode password if it contains @ # / etc.)
DATABASE_URL=postgresql://postgres:<url-encoded-db-password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
DB_CONN_MAX_AGE=120
DATABASE_SSLMODE=require

# ========== REQUIRED (email / contact) ==========
EMAIL_HOST=smtp.zoho.com
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_USE_TLS=False
EMAIL_HOST_USER=admin@duno360.com
EMAIL_HOST_PASSWORD=replace-with-zoho-app-password
CONTACT_EMAIL=admin@duno360.com
DEFAULT_FROM_EMAIL="DUNO 360 <admin@duno360.com>"
PLATFORM_PHONE=+242066790386

# ========== REQUIRED (media uploads — copy from your local .env) ==========
SUPABASE_STORAGE_ENABLED=True
SUPABASE_STORAGE_BUCKET=duno360
SUPABASE_S3_REGION=auto
SUPABASE_S3_ACCESS_KEY_ID=<supabase-s3-access-key-id>
SUPABASE_S3_SECRET_ACCESS_KEY=<supabase-s3-secret-access-key>
SUPABASE_S3_ENDPOINT=https://<project-ref>.storage.supabase.co/storage/v1/s3
SUPABASE_STORAGE_PUBLIC_BASE_URL=https://<your-public-cdn-or-supabase-url>

# ========== RECOMMENDED (payments — set KKIAPAY_SANDBOX=False when live) ==========
KKIAPAY_PUBLIC_KEY=<your-kkiapay-public-key>
KKIAPAY_PRIVATE_KEY=<your-kkiapay-private-key>
KKIAPAY_SECRET=<your-kkiapay-secret>
KKIAPAY_SANDBOX=False
KKIAPAY_WEBHOOK_SECRET=<your-webhook-secret>

PAWAPAY_API_TOKEN=<your-pawapay-api-token>
PAWAPAY_BASE_URL=https://api.pawapay.io
PAWAPAY_SANDBOX=False
PAWAPAY_ENABLED=True
PAWAPAY_CURRENCY=XAF
PAWAPAY_CALLBACK_DEPOSITS=https://duno360.com/manager/api/payment/pawapay/callback/deposits/
PAWAPAY_CALLBACK_PAYOUTS=https://duno360.com/manager/api/payment/pawapay/callback/payouts/
PAWAPAY_CALLBACK_REFUNDS=https://duno360.com/manager/api/payment/pawapay/callback/refunds/

# ========== RECOMMENDED (SMS signup verification) ==========
TWILIO_ACCOUNT_SID=<your-twilio-account-sid>
TWILIO_AUTH_TOKEN=<your-twilio-auth-token>
TWILIO_VERIFY_SERVICE_SID=<your-verify-service-sid-VA...>

# ========== OPTIONAL ==========
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
DJANGO_ADMIN_PASSWORD=replace-with-strong-admin-password
# REDIS_URL=redis://127.0.0.1:6379/1

# ========== DO NOT ADD IN PRODUCTION ==========
# NGROK_*          — dev tunnels only
# DB_NAME/DB_USER  — local postgres only; production uses DATABASE_URL
# 142.93.45.77     — old DigitalOcean IP; use 217.160.36.235

# ========== Tawk.to Live Chat ==========
TAWKTO_PROPERTY_ID=your-property-id-here
TAWKTO_WIDGET_ID=default
