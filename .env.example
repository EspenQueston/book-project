# ============================================
# DUNO 360 - Environment Variables
# Copy this file to .env and fill in values.
# NEVER commit the .env file to git.
# ============================================

# Django Core
DEBUG=False
SECRET_KEY=your-secret-key-here-generate-with-python-manage.py-generate_secret_key
ALLOWED_HOSTS=duno360.com,www.duno360.com,127.0.0.1,localhost
FORCE_HTTPS=True

# ----- PRODUCTION DATABASE (Supabase) -----
# URL-encode the password if it contains special characters.
DATABASE_URL=postgresql://postgres:YOUR-DB-PASSWORD@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
DB_CONN_MAX_AGE=120

# CSRF & Session
CSRF_TRUSTED_ORIGINS=https://duno360.com,https://www.duno360.com
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax

# Email (Zoho Mail — smtp.zoho.com, port 465 SSL)
EMAIL_HOST=smtp.zoho.com
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_USE_TLS=False
EMAIL_HOST_USER=admin@duno360.com
EMAIL_HOST_PASSWORD=your-zoho-app-password
CONTACT_EMAIL=admin@duno360.com
DEFAULT_FROM_EMAIL="DUNO 360 <admin@duno360.com>"
PLATFORM_PHONE=+242066790386

# Social media (optional overrides — defaults in settings.py)
# SOCIAL_FACEBOOK_URL=
# SOCIAL_INSTAGRAM_URL=
# SOCIAL_TIKTOK_URL=
# SOCIAL_YOUTUBE_URL=

# ============================================
# KKiaPay Payment Aggregator
# Get keys from: https://app.kkiapay.me/
# ============================================
KKIAPAY_PUBLIC_KEY=your-kkiapay-public-key
KKIAPAY_PRIVATE_KEY=your-kkiapay-private-key
KKIAPAY_SECRET=your-kkiapay-secret-key
KKIAPAY_SANDBOX=False
KKIAPAY_WEBHOOK_SECRET=your-webhook-secret-hash

# ============================================
# Supabase Storage (S3 compatible) for media
# ============================================
SUPABASE_STORAGE_ENABLED=True
SUPABASE_PROJECT_URL=https://<project-ref>.supabase.co
SUPABASE_STORAGE_BUCKET=duno360_bucket
SUPABASE_S3_REGION=us-east-1
SUPABASE_S3_ACCESS_KEY_ID=your-s3-access-key-id
SUPABASE_S3_SECRET_ACCESS_KEY=your-s3-secret-access-key
# Optional override (auto-derived from SUPABASE_PROJECT_URL if omitted):
# SUPABASE_S3_ENDPOINT=https://<project-ref>.storage.supabase.co/storage/v1/s3

# ============================================
# Twilio Verify — SMS OTP at signup
# Console: https://console.twilio.com/
# Create a Verify Service and paste its SID (starts with VA...)
# NEVER commit real credentials to git.
# ============================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# Cache (live product viewers — optional in local dev)
# If Redis is not running, DEBUG=True falls back to LocMem automatically.
# Start local Redis (WSL): .\scripts\start-redis.ps1
# ============================================
# REDIS_URL=redis://127.0.0.1:6379/1

# ============================================
# ngrok (development only — keep False in prod)
# ============================================
NGROK_AUTH_TOKEN=your-ngrok-auth-token
NGROK_ENABLED=False
NGROK_PUBLIC_URL=https://your-subdomain.ngrok-free.dev
# PawaPay — Central Africa (register callbacks in PawaPay dashboard)
PAWAPAY_API_TOKEN=your-pawapay-api-token
PAWAPAY_BASE_URL=https://api.sandbox.pawapay.io
PAWAPAY_SANDBOX=True
PAWAPAY_ENABLED=True
PAWAPAY_CURRENCY=XAF
# Auto-filled when NGROK_PUBLIC_URL is set:
# PAWAPAY_CALLBACK_DEPOSITS=
# PAWAPAY_CALLBACK_PAYOUTS=
# PAWAPAY_CALLBACK_REFUNDS=
# Enable "Signed Callbacks" in the PawaPay Dashboard (Security tab) first, then
# set this to True to REJECT unsigned/invalid callbacks. Leave False while
# rolling out — callbacks are verified and logged either way, just not rejected.
PAWAPAY_REQUIRE_SIGNED_CALLBACKS=False
# KKiaPay webhook (register in https://app.kkiapay.me/):
#   {NGROK_PUBLIC_URL}/manager/api/payment/kkiapay/webhook/

# ============================================
# Tawk.to Live Chat Widget
# Get from: https://dashboard.tawk.to → Administration → Property Settings
# ============================================
TAWKTO_PROPERTY_ID=your-property-id-here
TAWKTO_WIDGET_ID=default
