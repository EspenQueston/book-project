# ============================================
# DUNO 360 - Environment Variables
# Copy this file to .env and fill in values.
# NEVER commit the .env file to git.
# ============================================

# Django Core
DEBUG=False
SECRET_KEY=your-secret-key-here-generate-with-python-manage.py-generate_secret_key
ALLOWED_HOSTS=duno360.com,www.duno360.com,127.0.0.1,localhost
FORCE_HTTPS=True

# ----- PRODUCTION DATABASE (Supabase) -----
DATABASE_URL=postgresql://postgres:YOUR-DB-PASSWORD@db.gebnxwsrezadwuvmqtyy.supabase.co:5432/postgres
DB_CONN_MAX_AGE=120

# CSRF & Session
CSRF_TRUSTED_ORIGINS=https://duno360.com,https://www.duno360.com
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax

# Email
EMAIL_HOST_USER=your-email@domain.com
EMAIL_HOST_PASSWORD=your-email-password

# ============================================
# KKiaPay Payment Aggregator
# Get keys from: https://app.kkiapay.me/
# ============================================
KKIAPAY_PUBLIC_KEY=your-kkiapay-public-key
KKIAPAY_PRIVATE_KEY=your-kkiapay-private-key
KKIAPAY_SECRET=your-kkiapay-secret-key
KKIAPAY_SANDBOX=False
KKIAPAY_WEBHOOK_SECRET=your-webhook-secret-hash

# ============================================
# Supabase S3 Storage (for media files)
# ============================================
SUPABASE_S3_ACCESS_KEY=your-s3-access-key
SUPABASE_S3_SECRET_KEY=your-s3-secret-key
SUPABASE_S3_BUCKET=your-bucket-name
SUPABASE_S3_ENDPOINT=https://gebnxwsrezadwuvmqtyy.supabase.co/storage/v1/s3

# ============================================
# MTN MoMo
# ============================================
MTN_MOMO_SUBSCRIPTION_KEY=your-collection-subscription-key
MTN_MOMO_API_USER=auto-generated-uuid
MTN_MOMO_API_KEY=auto-generated-api-key
MTN_MOMO_ENVIRONMENT=sandbox
MTN_MOMO_CURRENCY=XAF
MTN_MOMO_CALLBACK_URL=https://duno360.com/manager/api/payment/mtn/callback/

# ============================================
# Airtel Money
# ============================================
AIRTEL_MONEY_CLIENT_ID=your-client-id
AIRTEL_MONEY_CLIENT_SECRET=your-client-secret
AIRTEL_MONEY_COUNTRY=CG
AIRTEL_MONEY_CURRENCY=XAF
AIRTEL_MONEY_CALLBACK_URL=https://duno360.com/manager/api/payment/airtel/callback/

# ============================================
# ngrok (development only — keep False in prod)
# ============================================
NGROK_AUTH_TOKEN=your-ngrok-auth-token
NGROK_ENABLED=False
