# ============================================
# Django Book Management System
# Production Environment Variables
# cPanel Deployment - scholarquest.tech
# ============================================

# Django Core
DEBUG=False
SECRET_KEY=your-secret-key-here-generate-a-new-one
ALLOWED_HOSTS=scholarquest.tech,www.scholarquest.tech,127.0.0.1,localhost

# PostgreSQL Database
DB_NAME=db_book
DB_USER=bookuser
DB_PASSWORD=your-db-password
DB_HOST=127.0.0.1
DB_PORT=5432

# Email Configuration (Gmail SMTP with App Password)
EMAIL_HOST_USER=bizkey2024@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password

# CSRF Trusted Origins (required for HTTPS)
CSRF_TRUSTED_ORIGINS=https://scholarquest.tech,https://www.scholarquest.tech
