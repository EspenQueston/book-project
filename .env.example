# ============================================
# DUNO 360 - Environment Variables
# Copy this file to .env and fill in values.
# NEVER commit the .env file to git.
# ============================================

# Django Core
DEBUG=False
SECRET_KEY=your-secret-key-here-generate-a-new-one
ALLOWED_HOSTS=159.203.186.103,scholarquest.tech,www.scholarquest.tech,127.0.0.1,localhost
DJANGO_ADMIN_PASSWORD=change-me-strong-password

# ----- PRODUCTION DATABASE (Supabase) -----
# Use DATABASE_URL for Supabase (recommended):
DATABASE_URL=postgresql://postgres:YOUR-DB-PASSWORD@db.gebnxwsrezadwuvmqtyy.supabase.co:5432/postgres
# OR use individual vars (leave DATABASE_URL blank to use these):
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=your-db-password
# DB_HOST=db.gebnxwsrezadwuvmqtyy.supabase.co
# DB_PORT=5432

# Email Configuration
EMAIL_HOST_USER=espen@profitexb2b.com
EMAIL_HOST_PASSWORD=your-email-password

# CSRF Trusted Origins (required for HTTPS)
CSRF_TRUSTED_ORIGINS=https://scholarquest.tech,https://www.scholarquest.tech

# ============================================
# MTN MoMo Sandbox Credentials
# Get from: https://momodeveloper.mtn.com/
# Run: python manage.py setup_mtn_sandbox --subscription-key YOUR_KEY
# ============================================
MTN_MOMO_SUBSCRIPTION_KEY=your-collection-subscription-key
MTN_MOMO_API_USER=auto-generated-uuid
MTN_MOMO_API_KEY=auto-generated-api-key
MTN_MOMO_ENVIRONMENT=sandbox
MTN_MOMO_CURRENCY=EUR
MTN_MOMO_CALLBACK_URL=https://your-ngrok-url.ngrok-free.app/manager/api/payment/mtn/callback/

# ============================================
# Airtel Money Sandbox Credentials
# Get from: https://developers.airtel.africa/
# ============================================
AIRTEL_MONEY_CLIENT_ID=your-client-id
AIRTEL_MONEY_CLIENT_SECRET=your-client-secret
AIRTEL_MONEY_COUNTRY=CG
AIRTEL_MONEY_CURRENCY=XAF
AIRTEL_MONEY_CALLBACK_URL=https://your-ngrok-url.ngrok-free.app/manager/api/payment/airtel/callback/

# ============================================
# ngrok (auto-tunnel for dev callbacks)
# ============================================
NGROK_AUTH_TOKEN=your-ngrok-auth-token
NGROK_ENABLED=False
