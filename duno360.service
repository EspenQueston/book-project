[Unit]
Description=DUNO 360 - Gunicorn Django Application
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/var/www/duno360
EnvironmentFile=/var/www/duno360/.env
ExecStart=/var/www/duno360/venv/bin/gunicorn \
    --config /var/www/duno360/gunicorn.conf.py \
    book_Project.wsgi:application
ExecReload=/bin/kill -s HUP $MAINPID
KillMode=mixed
TimeoutStopSec=5
PrivateTmp=true
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
